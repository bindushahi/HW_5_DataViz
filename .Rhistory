library(MASS)
library(ggplot2)
cars93 <- MASS::Cars93
# LOESS smoothing
ggplot(cars93, aes(x = Price, y = Fuel.tank.capacity)) +
geom_point(color = "grey60") +
geom_smooth(method = "loess", se = TRUE, formula = y ~ x, color = "#0072B2") +
scale_x_continuous(
name = "price (USD)",
breaks = c(20, 40, 60),
labels = c("$20,000", "$40,000", "$60,000")
) +
scale_y_continuous(name = "fuel-tank capacity\n(US gallons)") +
ggtitle("LOESS smoothing") +
theme(plot.title = element_text(size = 14, color = "#0072B2"))
# Linear model (lm)
ggplot(cars93, aes(x = Price, y = Fuel.tank.capacity)) +
geom_point(color = "grey60") +
geom_smooth(method = "lm", se = TRUE, color = "#8fe388") +
scale_x_continuous(
name = "price (USD)",
breaks = c(20, 40, 60),
labels = c("$20,000", "$40,000", "$60,000")
) +
scale_y_continuous(name = "fuel-tank capacity\n(US gallons)") +
ggtitle("Linear Model (lm)") +
theme(plot.title = element_text(size = 14, color = "#8fe388"))
# Generalized linear model (glm)
ggplot(cars93, aes(x = Price, y = Fuel.tank.capacity)) +
geom_point(color = "grey60") +
geom_smooth(method = "glm", se = TRUE, color = "#fe8d6d") +
scale_x_continuous(
name = "price (USD)",
breaks = c(20, 40, 60),
labels = c("$20,000", "$40,000", "$60,000")
) +
scale_y_continuous(name = "fuel-tank capacity\n(US gallons)") +
ggtitle("Generalized Linear Model (glm)") +
theme(plot.title = element_text(size = 14, color = "#fe8d6d"))
# Generalized additive model (gam)
ggplot(cars93, aes(x = Price, y = Fuel.tank.capacity)) +
geom_point(color = "grey60") +
geom_smooth(method = "gam", se = TRUE, color = "#7c6bea") +
scale_x_continuous(
name = "price (USD)",
breaks = c(20, 40, 60),
labels = c("$20,000", "$40,000", "$60,000")
) +
scale_y_continuous(name = "fuel-tank capacity\n(US gallons)") +
ggtitle("Generalized Additive Model (gam)") +
theme(plot.title = element_text(size = 14, color = "#7c6bea"))
