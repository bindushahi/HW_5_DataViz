#Qno.5
library(dplyr)
library(ggplot2)
library(lubridate)
# Load the dataset
load("C:/Users/user/Desktop/preprint_growth.rda")
# Get rows with count > 0 and year > 2004
preprint_full <- preprint_growth %>%
filter(count > 0, year(date) > 2004)
# Select only bioRxiv and F1000Research
preprints_selected <- preprint_full %>%
filter(archive %in% c("bioRxiv", "F1000Research"))
# Draw line plot
ggplot(preprints_selected, aes(x = date, y = count, color = archive)) +
geom_line(size = 1) +
scale_color_manual(values = c("bioRxiv" = "#7c6bea", "F1000Research" = "#fe8d6d")) +
ggtitle("Preprint Counts") + # plot title
theme(plot.title = element_text(size = 14)) +
theme(legend.position = "right") + # move legend to right
scale_x_date(name = "year", limits = c(as.Date("2014-02-01"), max(preprints_selected$date))) +
scale_y_continuous(name = "preprints / month")
